{
  "name": "project-manager",
  "version": "1.3.0",
  "description": "Obsidian Project Manager Plugin",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && oxlint ./src && node esbuild.config.mjs production",
    "check": "run-p check:**",
    "check:code": "oxlint ./src",
    "check:format": "oxfmt --check ./src",
    "check:types": "tsc -noEmit -skipLibCheck",
    "fix": "run-p fix:**",
    "fix:code": "oxlint --fix ./src",
    "fix:format": "oxfmt ./src"
  },
  "devDependencies": {
    "@2bad/axiom": "2.0.0",
    "@2bad/tsconfig": "3.0.2",
    "@types/node": "25.6.0",
    "builtin-modules": "3.3.0",
    "esbuild": "0.25.0",
    "eslint-plugin-obsidianmd": "0.2.4",
    "npm-run-all2": "8.0.4",
    "obsidian": "latest",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "typescript": "6.0.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "volta": {
    "node": "24.15.0",
    "pnpm": "10.33.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
